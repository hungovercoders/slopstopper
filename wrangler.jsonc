{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slopstopper",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./app",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "html_handling": "none",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
