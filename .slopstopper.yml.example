# .slopstopper.yml — repo-level config for slopstopper.
#
# Survives install.sh re-runs (the installer only seeds it once if
# .slopstopper.yml doesn't exist; it never overwrites an existing file).
# Slopstopper scripts and workflows that need a per-repo value read from
# here first.
#
# What lives here:
#   - Defaults for env-var-driven checks (URLs, page lists, og-image path)
#   - Tuning knobs that would otherwise be hardcoded into workflows and
#     wiped on every reinstall
#   - Adapter selection for the CSP-drift check (so adopters with
#     different header-source formats are first-class, not second-class)
#   - Workflows to skip on this repo
#
# What does NOT live here:
#   - Secrets (use GitHub Actions secrets)
#   - Anything platform-specific that's already a Cloudflare/Vercel/Netlify
#     native config (e.g. wrangler.jsonc, vercel.json, netlify.toml)

# ── Node version pin ─────────────────────────────────────────────────
# Workflows use ${{ vars.SLOPSTOPPER_NODE_VERSION || '20' }} in their
# setup-node steps. Set the repo variable from this value with:
#   gh variable set SLOPSTOPPER_NODE_VERSION --body "$(yq '.node_version' .slopstopper.yml)"
# Or set it directly via the GitHub repo settings UI.
node_version: '20'

# ── Headers drift check adapter ──────────────────────────────────────
# The ss:hygiene:csp-exceptions check enforces that every per-path CSP
# relaxation in your header source has a matching entry in
# docs/security/CSP_EXCEPTIONS.md. Tell it where your headers live and
# what format the file is in. Set source: null to skip the check
# entirely (use this if you manage headers via framework middleware,
# platform config, etc., and want to handle drift another way).
headers:
  # Path to the file the adapter parses. Common values:
  #   worker/headers.json     — Cloudflare Worker with JSON-driven headers (slopstopper.dev pattern)
  #   public/_headers         — Cloudflare/Netlify static-asset _headers convention
  #   app/_headers            — same convention, served from app/ directory
  source: worker/headers.json
  # Adapter to use when parsing. Shipped adapters:
  #   json              — [{for, values}, ...] JSON array
  #   cloudflare-text   — Cloudflare _headers text format
  # Set to 'auto' to infer from the file extension (json→json, no-ext→cloudflare-text).
  format: json

# ── Dynamic-check URLs ───────────────────────────────────────────────
# Reliability + DAST workflows pick a URL based on the event:
#   - push to main / scheduled  → urls.production
#   - pull_request              → urls.preview (falls back to local build if unset)
#   - workflow_dispatch         → arg, then preview, then production
# Sync to GitHub repo variables with:
#   bash .ss/scripts/sync-config-to-vars.sh   # (helper added by install.sh)
urls:
  production:
  preview:

# Pages to exercise on each dynamic check (comma-separated paths).
# Workflows read these via .ss/scripts/load_config.py and fall back to '/'
# if unset. Override per check, e.g. `accessibility: /,/blog,/about`.
pages:
  smoke:         /
  accessibility: /
  seo:           /
  broken_links:  /

# ── Smoke test customizations ────────────────────────────────────────
smoke:
  # Path to a site-wide og-image. Set to '' to skip the og-image assertion
  # entirely (use this if you ship per-post share images instead of one
  # site-wide image).
  og_image_path: /og-image.png

# ── Hygiene-check thresholds ─────────────────────────────────────────
# Every hygiene check reads its own thresholds from here, falling back
# to the defaults shown if a key is unset. Raise them for monorepos /
# heavy docs, lower them if your repo is small and you want tighter
# limits. Adopters typically only need to tune these when a check
# starts failing for a reason that's actually fine (e.g. you intentionally
# have 30 docs pages, max_files: 25 is wrong for you — not your docs).
hygiene:
  docs_size:
    # Total markdown size under docs/ before the report flags an alert.
    # Includes every .md file except docs/archive/**.
    max_total_size_kb: 150
    # Largest single doc before the report flags it.
    max_file_size_kb: 20
    # Total number of doc files before the report flags it.
    max_files: 25
  entry_files:
    # Hard cap for entry files (README.md, CLAUDE.md, AGENTS.md, etc.).
    # ~1500 words ≈ ~2000 tokens — see docs/hygiene/ for the rationale.
    max_words: 1500

# ── Reliability coverage modes ───────────────────────────────────────
# Each reliability check (accessibility, seo, broken_links, smoke) needs
# to know which pages to audit. By default it uses pages.<check> above.
# For larger sites, opt into one of the smarter modes per CI event:
#   "sitemap"      — read every <loc> in dist/client/sitemap-index.xml
#                    (or sibling fallbacks). Requires a build step before
#                    the check; great for "audit everything on main".
#   "changed"      — diff origin/main...HEAD, map each changed source
#                    file to its output URL (Astro / Next / SvelteKit
#                    auto-detected). PR-only; falls back to sitemap if
#                    git history is missing. Great for "fast PR audits".
#   "/,/path,..."  — explicit comma-separated list (overrides pages.<check>).
#
# Unset keys fall back to pages.<check>.
reliability:
  coverage:
    pr: changed
    main: sitemap
    cron: sitemap
    # When a changed-mode PR touches one of these glob-matched files,
    # the check escalates to a full sitemap sweep (because the change is
    # cross-cutting and would affect every page). Empty list = never
    # escalate.
    cross_cutting_paths:
      - 'src/layouts/**'
      - 'astro.config.*'
      - 'tailwind.config.*'
      - 'package.json'

# ── Workflows to skip on this repo ───────────────────────────────────
# install.sh removes any workflow named here from .github/workflows/
# (and remembers the deletion via .ss/.workflows-installed so re-runs
# don't bring them back). Same semantics as manually deleting the file.
workflows:
  disabled: []
