# .slopstopper.yml — repo-level config for slopstopper.
#
# This file serves a dual role:
#   - Schema reference: the canonical inventory of every key slopstopper
#     checks and workflows read. Adopters and agents link to it.
#   - Adopter seed: install.sh copies this file into adopter repos as
#     `.slopstopper.yml` on first install. Existing files are never
#     overwritten — re-running install.sh is safe.
#
# Slopstopper scripts and workflows that need a per-repo value read from
# here first. Defaults below are the values used when a key is unset.
#
# What lives here:
#   - Defaults for env-var-driven checks (URLs, page lists, og-image path)
#   - Per-check thresholds that would otherwise be hardcoded into scripts
#     and wiped on every reinstall
#   - Adapter selection for the CSP-drift check (so adopters with different
#     header-source formats are first-class, not second-class)
#   - Workflows to skip on this repo
#
# What does NOT live here:
#   - Secrets (use GitHub Actions secrets)
#   - Anything platform-specific that's already a Cloudflare/Vercel/Netlify
#     native config (e.g. wrangler.jsonc, vercel.json, netlify.toml)

# ── slopstopper-cli version pin ──────────────────────────────────────
# The CLI version is NOT pinned here. It lives in mise.toml ([tools]
# "pipx:slopstopper-cli"), the single source of truth that both local runs
# and CI (via jdx/mise-action) read. mise installs it and activates it
# per-directory, so the active version follows the repo — no global binary to
# drift between repos. install.sh manages the pin:
#   install.sh                    # honour the pin in mise.toml (never bumps)
#   install.sh --upgrade-cli      # bump to the latest on PyPI
#   install.sh --cli-version X.Y.Z  # pin to an exact version
# A legacy cli_version key here is migrated into mise.toml and removed on the
# next install.

# ── Node version pin ─────────────────────────────────────────────────
# Workflows use ${{ vars.SLOPSTOPPER_NODE_VERSION || '20' }} in their
# setup-node steps. If your project needs Node 22+ (Astro 6, recent
# Next, SvelteKit), bump this AND set the GitHub repo variable:
#   gh variable set SLOPSTOPPER_NODE_VERSION --body "$(yq '.node_version' .slopstopper.yml)"
# Or set it directly via the GitHub repo settings UI.
node_version: '20'

# ── Headers drift check adapter ──────────────────────────────────────
# The hygiene:csp-exceptions check enforces that every per-path CSP
# relaxation in your header source has a matching entry in
# docs/security/CSP_EXCEPTIONS.md, and vice versa.
#
# Set source to the path to your headers file. Common values:
#   public/_headers         Cloudflare Pages, Cloudflare Workers Builds, Netlify
#   app/_headers            same convention served from app/
#   worker/headers.json     Cloudflare Worker with JSON-driven headers
#
# Set source: null to skip the check entirely (use this if you manage
# headers via framework middleware, platform config, etc., and want to
# handle drift another way).
headers:
  source: null
  # Adapter to use when parsing. Shipped:
  #   json              [{for, values}, ...] JSON array
  #   cloudflare-text   Cloudflare _headers text format
  #   auto              infer from extension (json→json, no-ext→cloudflare-text)
  format: auto

# ── Dynamic-check URLs ───────────────────────────────────────────────
# Reliability + DAST workflows pick a URL based on the event:
#   - push to main / scheduled  → urls.production
#   - pull_request              → urls.preview (falls back to local build if unset)
#   - workflow_dispatch         → arg, then preview, then production
# Sync to GitHub repo variables with:
#   bash .ss/scripts/sync-config-to-vars.sh   # (helper added by install.sh)
urls:
  production:
  preview:

# ── Pages to audit on each dynamic check ─────────────────────────────
# Hand-list of paths each reliability check audits. Simple and predictable,
# but goes stale every time a new page or content type lands. For larger
# sites, prefer the `reliability.coverage.*` block below — it derives the
# list from your sitemap or git diff automatically.
#
# Defaults to '/' for every check when unset.
pages:
  smoke:         /
  accessibility: /
  seo:           /
  broken_links:  /

# ── Smoke test customizations ────────────────────────────────────────
smoke:
  # Path to a site-wide og-image. Set to '' to skip the og-image assertion
  # entirely (use this if you ship per-post share images instead of one
  # site-wide image).
  og_image_path: /og-image.png

# ── Hygiene-check thresholds ─────────────────────────────────────────
# Every hygiene check reads its own thresholds from here. Values shown
# are the defaults used when a key is unset. Tune when a check fails for
# a reason that's actually fine (e.g. you intentionally have 30 docs
# pages, and `max_files: 25` is the wrong shape for you — not your docs).
# Don't tune to silence noise; tune to match a deliberate design decision.
hygiene:
  docs_size:
    # Total markdown size under docs/ before the report flags an alert.
    # Excludes docs/archive/**.
    max_total_size_kb: 150
    # Largest single doc before the report flags it.
    max_file_size_kb: 20
    # Total number of doc files before the report flags it.
    max_files: 25
  entry_files:
    # Hard cap for entry files (README.md, CLAUDE.md, AGENTS.md, etc.).
    # ~1500 words ≈ ~2000 tokens — see docs/hygiene/ for the rationale.
    max_words: 1500
    # Map Pattern pointer rule. When true (default), the check fails if
    # README.md or AGENTS.md don't link to the docs map, if CLAUDE.md
    # isn't a thin pointer to AGENTS.md (link or `@AGENTS.md` directive),
    # or if the map file itself doesn't exist. The check's report emits a
    # paste-ready snippet for each violation. Flip to false to disable
    # the whole pointer rule (the word-budget rule still applies).
    require_map_pointer: true
    # Path to the docs map, relative to the repo root. Override if you
    # keep your map somewhere other than docs/index.md.
    map_path: docs/index.md

# ── Reliability coverage modes ───────────────────────────────────────
# Opt-in alternative to the hand-list above. When set, accessibility,
# seo and broken_links resolve which paths to audit via:
#
#   sitemap   → every URL in dist/client/sitemap-index.xml (or fallback
#               candidates like dist/sitemap.xml). Run `npm run build`
#               first; CI workflows do this automatically.
#   changed   → on PRs only: git diff origin/main...HEAD → map source
#               files to URLs via framework source_to_url rules (Astro /
#               Next.js / SvelteKit auto-detected from config files).
#               Auto-escalates to sitemap when any changed file matches
#               cross_cutting_paths.
#   /a,/b     → explicit hand-list, same shape as pages.* above.
#
# When the resolved set is empty (no sitemap, no matched changed files,
# git history missing), discovery falls through gracefully: changed →
# sitemap → pages.<check> → "/". Better to over-test than to silently
# no-op a quality gate.
#
# Unset = fall back to pages.<check>.
#
# reliability:
#   coverage:
#     pr: changed
#     main: sitemap
#     cron: sitemap
#     # When a `changed`-mode PR touches one of these glob-matched files,
#     # the check escalates to a full sitemap sweep (because the change
#     # is cross-cutting and would affect every page). Empty list = never
#     # escalate.
#     cross_cutting_paths:
#       - 'src/layouts/**'
#       - 'astro.config.*'
#       - 'tailwind.config.*'
#       - 'package.json'

# ── Workflows to skip on this repo ───────────────────────────────────
# install.sh removes any workflow named here from .github/workflows/
# (and remembers the deletion via .ss/.workflows-installed so re-runs
# don't bring them back). Same semantics as manually deleting the file.
workflows:
  disabled: []
