# .slopstopper.yml — repo-level config for slopstopper.
#
# Seeded by install.sh. Survives subsequent install.sh re-runs (the
# installer only creates this file if it doesn't already exist; it
# never overwrites an existing one). Slopstopper scripts and workflows
# that need a per-repo value read from here.
#
# See https://github.com/hungovercoders/slopstopper/blob/main/.slopstopper.yml.example
# for the fully-populated schema reference.

# ── Node version pin ─────────────────────────────────────────────────
# Workflows use ${{ vars.SLOPSTOPPER_NODE_VERSION || '20' }} in their
# setup-node steps. If your project needs Node 22+ (Astro 6, recent
# Next, SvelteKit kit), bump this AND set the GitHub repo variable:
#   gh variable set SLOPSTOPPER_NODE_VERSION --body "$(yq '.node_version' .slopstopper.yml)"
node_version: '20'

# ── Headers drift check adapter ──────────────────────────────────────
# The ss:hygiene:csp-exceptions check enforces that every per-path CSP
# relaxation in your header source has a matching entry in
# docs/security/CSP_EXCEPTIONS.md.
#
# Set source to the path to your headers file. Common values:
#   public/_headers         Cloudflare Pages, Cloudflare Workers Builds (assets), Netlify
#   app/_headers            same convention served from app/
#   worker/headers.json     Cloudflare Worker with JSON-driven headers
#
# Set source: null to skip the check entirely (use this if you manage
# headers via framework middleware, platform config, etc., and want
# to handle drift another way).
headers:
  source: null
  # Adapter to use. Shipped: json, cloudflare-text. 'auto' infers from extension.
  format: auto

# ── Dynamic-check URLs ───────────────────────────────────────────────
# Reliability + DAST workflows pick a URL based on the event.
urls:
  production:
  preview:

# Pages to exercise on each dynamic check (comma-separated paths).
# This is the hand-list path: simple, predictable, easy to skim. For
# real adopters, prefer the `reliability:` block below to stop the list
# going stale every time a new page or content type lands.
pages:
  smoke:         /
  accessibility: /
  seo:           /
  broken_links:  /

# ── Reliability coverage (sitemap + changed-pages) ───────────────────
# Opt-in alternative to the hand-list above. When set, the accessibility
# / SEO / broken-links checks resolve which paths to audit via:
#
#   sitemap   → every URL in dist/client/sitemap-index.xml (or fallback
#               candidates like dist/sitemap.xml). Run `npm run build`
#               first; CI workflows do this automatically.
#   changed   → on PRs only: git diff origin/main...HEAD → map source
#               files to URLs via the framework's source_to_url rules
#               (Astro / Next.js / SvelteKit are auto-detected from
#               their config files). Auto-escalates to sitemap when any
#               changed file matches cross_cutting_paths.
#   /a,/b     → explicit hand-list, same shape as pages.* above.
#
# When the resolved set is empty (no sitemap, no matched changed files,
# git history missing), discovery falls through to sitemap, then to
# pages.<check>, then to "/". Better to over-test than to silently
# no-op a quality gate.
#
# cross_cutting_paths MUST use the inline-list form ([a, b]) — the
# stdlib YAML subset in .ss/scripts/load_config.py doesn't parse the
# multi-line "- item" form under nested keys. Tracked as a follow-up.
#
# reliability:
#   coverage:
#     pr:   changed
#     main: sitemap
#     cron: sitemap
#     cross_cutting_paths: [
#       'src/layouts/*',
#       'src/components/Base*.astro',
#       'src/components/Header.astro',
#       'src/components/Footer.astro',
#       'src/styles/*',
#       'astro.config.*',
#       'tailwind.config.*',
#     ]

# ── Smoke test customizations ────────────────────────────────────────
smoke:
  # Path to a site-wide og-image. Set to '' to skip the og-image
  # assertion entirely (use if you ship per-post share images).
  og_image_path: /og-image.png

# ── Hygiene-check thresholds ─────────────────────────────────────────
# Every hygiene check reads its own thresholds from here. Defaults shown
# are what the check uses if the key is unset. Tune when a check fails
# for a reason that's actually fine (e.g. you intentionally have 30 docs
# pages and `max_files: 25` is the wrong shape for you — not your docs).
#
# hygiene:
#   docs_size:
#     max_total_size_kb: 150   # all .md under docs/ (excluding docs/archive/**)
#     max_file_size_kb: 20     # largest single doc
#     max_files: 25            # total doc count
#   entry_files:
#     max_words: 1500          # README.md, CLAUDE.md, AGENTS.md, etc.

# ── Workflows to skip on this repo ───────────────────────────────────
workflows:
  disabled: []
